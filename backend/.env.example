PORT=4000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lotes_web

JWT_SECRET=cambia_esta_clave_por_una_segura
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

# Credenciales del admin inicial (solo usadas en db:seed)
ADMIN_EMAIL=admin@lotes.pe
ADMIN_PASSWORD=admin123

UPLOAD_DIR=uploads

# API externa de catálogo de proyectos (CRM)
# Producción/staging CRM (mismo origen que mobile EXPO_PUBLIC_API_BASE_URL)
WEB_API_BASE_URL=https://inmopro.laravel.cloud
# Local con Herd/Valet: https://crm-lotes.test
WEB_API_TIPO_WEB=lotesenremate.pe
WEB_API_TIMEOUT_MS=15000
