PORT=4000

NODE_ENV=production
# MySQL: puede ser el de cPanel (acceso remoto) o el del mismo host del API
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=
DB_NAME=lotes_web_backend

JWT_SECRET=cambia_esta_clave_por_una_segura_larga
JWT_EXPIRES_IN=7d

# Dominio del sitio en cPanel (sin barra final)
CORS_ORIGIN=https://lotesenremate.pe
ADMIN_EMAIL=admin@lotes.pe
ADMIN_PASSWORD=cambia_esta_contraseña
# Ruta absoluta en el servidor del API (carpeta uploads con permiso de escritura)

UPLOAD_DIR=/var/app/uploads



# URL pública del API (para URLs de imágenes/videos subidos)
API_BASE_URL=https://api.lotesenremate.pe
WEB_API_BASE_URL=https://inmopro.laravel.cloud
WEB_API_TIPO_WEB=lotesenremate.pe
WEB_API_TIMEOUT_MS=15000

