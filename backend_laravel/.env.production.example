# Referencia para producción en Banahosting — https://v1.lotesenremate.pe
# Copiar a .env en el servidor (no commitear credenciales reales)

APP_NAME="Lotes en Remate"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://v1.lotesenremate.pe

CORS_ORIGIN=https://lotesenremate.pe
SANCTUM_STATEFUL_DOMAINS=lotesenremate.pe

API_BASE_URL=https://v1.lotesenremate.pe

WEB_API_BASE_URL=https://inmopro.laravel.cloud
WEB_API_TIPO_WEB=lotesenremate.pe
WEB_API_TIMEOUT_MS=15000

ADMIN_EMAIL=admin@lotes.pe
ADMIN_PASSWORD=

APP_LOCALE=es
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
