# URL base de la API
# Desarrollo (con proxy Vite): /api
# Producción: https://tudominio.com/api
VITE_API_URL=/api

# Target del proxy de Vite → backend Express (solo desarrollo)
VITE_DEV_API_PROXY=http://localhost:4000

# Claves de localStorage
VITE_AUTH_STORAGE_KEY=lotes_auth_token
VITE_AUTH_EMAIL_KEY=lotes_admin_email
VITE_THEME_STORAGE_KEY=lotes_theme
